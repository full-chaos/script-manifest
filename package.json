{
  "name": "script-manifest",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "pnpm run test:unit",
    "test:integration": "node --import tsx --test --test-concurrency=1 tests/integration/compose/**/*.test.ts",
    "test:integration:compose": "bash ./scripts/compose-integration-harness.sh test",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:update": "playwright test --config tests/e2e/playwright.config.ts --update-snapshots",
    "test:packages": "pnpm -r --filter './packages/*' test",
    "test:services": "pnpm -r --filter './services/*' test",
    "test:web": "pnpm -r --filter './apps/writer-web' test",
    "manage-admin": "node --import tsx scripts/manage-admin.ts",
    "bundle:manage-admin": "esbuild scripts/manage-admin.ts --bundle --platform=node --format=cjs --outfile=scripts/manage-admin.cjs --external:pg --external:pg-native",
    "test:ops": "node --test scripts/ci/**/*.test.mjs",
    "test:unit": "turbo run test && pnpm run test:ops",
    "test:coverage": "bash ./scripts/run-coverage.sh",
    "test:coverage:services": "rm -rf .coverage/services && mkdir -p .coverage/services/tmp && c8 --all --temp-directory .coverage/services/tmp --report-dir .coverage/services --reporter=text-summary --reporter=json-summary --reporter=lcovonly pnpm -r --filter './services/*' test",
    "test:coverage:web": "pnpm -r --filter './apps/writer-web' test:coverage",
    "test:inventory": "bash ./scripts/check-test-inventory.sh",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "c8": "^11.0.0",
    "esbuild": "^0.27.4",
    "eslint": "9.20.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "^5.5.6",
      "readdir-glob>minimatch": "^5.1.8"
    }
  }
}
